# ==============================================================================
# Dependencies & Package Managers
# ==============================================================================
# Exclude node_modules if you use npm/yarn for tooling (like Live Server or Prettier)
node_modules/
.pnp
.pnp.js

# ==============================================================================
# Build Outputs & Production Artifacts
# ==============================================================================
# Exclude build output folders if you use static bundlers (Vite, Parcel, etc.)
dist/
build/
out/
.parcel-cache/

# ==============================================================================
# Environment Variables & Secrets
# ==============================================================================
# Block local environment variables that might hold API keys or private tokens
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==============================================================================
# Text Editor & IDE Configurations
# ==============================================================================
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# WebStorm / IntelliJ
.idea/

# Sublime Text
*.sublime-project
*.sublime-workspace

# ==============================================================================
# Operating System Junk Files
# ==============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini

# ==============================================================================
# Logs and Backups
# ==============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.sass-cache/